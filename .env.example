# Shared
APP_ENV=local

# Web
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=tr
NEXT_PUBLIC_SUPPORTED_LOCALES=tr,en
# Base URL for all API calls from Next.js (public site + admin UI)
# Must point to the running Spring Boot API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
# Docker Compose — baked into the Next.js image for the *browser* (host machine). Use localhost + the
# published API port so admin login and client fetches work. If the API host port is not 8080, set e.g.
# DOCKER_NEXT_PUBLIC_API_BASE_URL=http://localhost:9090/api/v1 and rebuild the web image.
# DOCKER_NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
# Server-side / middleware in the web container use API_INTERNAL_BASE_URL (default http://api:8080/api/v1 in compose).
# API_INTERNAL_BASE_URL=http://api:8080/api/v1

# API
API_PORT=8080
SPRING_PROFILES_ACTIVE=local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=krontech
DB_USER=krontech
DB_PASSWORD=krontech
# Schema is Flyway-only (Hibernate ddl-auto: validate). If you previously ran older Flyway versions
# against this database, reset once: `docker compose down -v` or DROP SCHEMA public CASCADE; CREATE SCHEMA public;
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=replace_with_a_long_random_secret
JWT_ISSUER=krontech-api
# On-demand ISR revalidation (backend → Next.js)
# Both values must be set and match for immediate cache invalidation on publish.
# If blank, the ISR TTL governs cache freshness instead (max 2 h).
# WEB_APP_URL: internal URL the backend uses to reach the Next.js server.
#   Local dev: http://localhost:3000 (default)
#   Docker (API inside container): http://host.docker.internal:3000
#   Production: https://www.krontech.com.tr
WEB_APP_URL=http://localhost:3000
REVALIDATE_SECRET=replace_with_a_long_random_secret
# Comma-separated list of origins allowed to make cross-origin requests to the API.
# Local dev: the Next.js dev server origin (default port 3000).
# Production: the public site domain and any admin app domain.
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Object storage (MinIO in local dev / AWS S3 in production)
# S3_ENDPOINT     — Internal URL the API uses to connect to storage.
#                   Local: http://localhost:9000  |  AWS: https://s3.amazonaws.com
# S3_PUBLIC_ENDPOINT — URL returned in media publicUrl for browsers.
#                   Leave blank to use the same as S3_ENDPOINT.
#                   Production: set to your CDN URL (e.g. https://cdn.krontech.com.tr)
# S3_FORCE_PATH_STYLE — true for MinIO; false for AWS S3 (uses virtual-hosted style).
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=media
S3_FORCE_PATH_STYLE=true
# Upload size limits (Spring Boot multipart)
MAX_UPLOAD_FILE_SIZE=20MB
MAX_UPLOAD_REQUEST_SIZE=22MB
